# =========================================================
# PERFIL ACTIVO
# =========================================================
SPRING_PROFILES_ACTIVE=docker

# =========================================================
# SERVIDOR
# =========================================================
SERVER_PORT=8082
APP_PORT=8082

# =========================================================
# BASE DE DATOS - DOCKER
# =========================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=5434
POSTGRES_DB=commerce_core_db
POSTGRES_USER=commerce_user
POSTGRES_PASSWORD=commerce_pass

# =========================================================
# JWT
# =========================================================
JWT_SECRET=8f1b5d3c7a9e2f4b6c8d0e1f3a5b7c9d2e4f6a8b0c1d3e5f7a9b2c4d6e8f0a1
